# Repo root (auto-detected as ../../ from apps/fpv-tool if unset)
# FPV_REPO_ROOT=/path/to/fpv-drone-strikes-lebanon-dataset

# Scene data directory (default: $FPV_REPO_ROOT/scenes)
# FPV_SCENES_DIR=

# Python VGGT / annotation backend (proxied for /api/*)
FPV_PYTHON_API_URL=http://127.0.0.1:8766

# Scene binaries (point clouds, camera frames, scene_meta.json) — empty = same origin / local files
# FPV_ASSET_ROOT=

# Production on S3/CloudFront (same distribution as FPV videos):
# FPV_ASSET_ROOT=https://d2fioemadmrru3.cloudfront.net

# When embedding in itamarwe.github.io, set e.g. /research/fpv-drone-strikes
# NEXT_PUBLIC_BASE_PATH=
# FPV_APP_BASE=/research/fpv-drone-strikes
