{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FPV dataset catalog",
  "type": "object",
  "required": ["schema_version", "videos"],
  "properties": {
    "schema_version": { "const": 1 },
    "videos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "description", "town", "provenance", "media"],
        "properties": {
          "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}_[a-z0-9_]+$" },
          "date": { "type": "string", "format": "date" },
          "description": { "type": "string", "minLength": 1 },
          "original_title": { "type": "string" },
          "town": { "type": "string", "minLength": 1 },
          "provenance": {
            "type": "object",
            "required": ["source"],
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "source_url": { "type": "string", "format": "uri" },
              "channel": { "type": "string", "minLength": 1 },
              "message_id": { "type": ["string", "integer"] },
              "discovered_at": { "type": "string", "format": "date-time" }
            },
            "additionalProperties": false
          },
          "media": {
            "type": "object",
            "required": ["video_key", "thumbnail_key"],
            "properties": {
              "video_key": { "type": "string" },
              "thumbnail_key": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
