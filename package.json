{
  "name": "fpv-drone-strikes-lebanon-dataset",
  "private": true,
  "description": "FPV drone strike dataset: video references, annotations, and the annotation/scene tooling. npm scripts here publish the web data consumed by itamarweiss.com/fpv.",
  "scripts": {
    "audit": "node tools/catalog/audit_catalog.mjs",
    "catalog:generate": "node tools/catalog/generate_views.mjs",
    "catalog:check": "node tools/catalog/generate_views.mjs --check && npm run audit",
    "redirects:test": "node tools/catalog/test_redirect_function.mjs",
    "dataset:add": "node tools/catalog/dataset.mjs add",
    "dataset:annotate": "node tools/catalog/dataset.mjs annotate",
    "dataset:add-scene": "node tools/catalog/dataset.mjs add-scene",
    "dataset:unpublish-scenes": "node tools/catalog/dataset.mjs unpublish-scenes",
    "dataset:rename": "node tools/catalog/dataset.mjs rename",
    "dataset:publish": "node tools/catalog/dataset.mjs publish",
    "dataset:verify": "node tools/catalog/dataset.mjs verify",
    "check-public": "node tools/catalog/check_public_assets.mjs",
    "normalize-annotations": "node tools/catalog/normalize_annotations.mjs --apply",
    "gen-thumbnails": "node tools/publishing/gen_thumbnails.mjs",
    "apply-calibration": "node tools/publishing/apply_calibration.mjs",
    "build-web-data": "node tools/publishing/build_web_data.mjs",
    "publish-web": "tools/publishing/publish_web.sh",
    "publish-web:fast": "tools/publishing/publish_web.sh --skip-scenes"
  },
  "devDependencies": {
    "sharp": "^0.33.0"
  }
}
